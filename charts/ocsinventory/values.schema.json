{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "affinity": {
            "description": "Affinity",
            "type": "object"
        },
        "database": {
            "description": "Configuration for the database on an existing server",
            "type": "object",
            "properties": {
                "create": {
                    "description": "If true, you must supply the password for the user root",
                    "type": "boolean"
                },
                "database": {
                    "description": "Database name. db-name in the secret",
                    "type": "string"
                },
                "existingSecret": {
                    "description": "The name for an existing secret. Please refer to templates/secrets.yaml for the minimal content.",
                    "type": "string"
                },
                "hostname": {
                    "description": "Database hostname. db-host in the secret",
                    "type": "string"
                },
                "password": {
                    "description": "Database password. db-password in the secret",
                    "type": "string"
                },
                "root_password": {
                    "description": "The password for the user root - root-pass in the secret",
                    "type": "string"
                },
                "username": {
                    "description": "Database username. db-user in the secret",
                    "type": "string"
                }
            }
        },
        "deployment": {
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Deployment annotations",
                    "type": "object"
                },
                "labels": {
                    "description": "Deployment labels",
                    "type": "object"
                },
                "replicaCount": {
                    "description": "Number of replicas to be deployed",
                    "type": "integer"
                }
            }
        },
        "dnsConfig": {
            "description": "DNS config",
            "type": "object"
        },
        "dnsPolicy": {
            "description": "DNS policy",
            "type": "string"
        },
        "extraEnv": {
            "description": "Extra environment",
            "type": "array"
        },
        "extraVolumeMounts": {
            "description": "Extra volume mounts",
            "type": "array"
        },
        "extraVolumes": {
            "description": "Extra volumes",
            "type": "array"
        },
        "fullnameOverride": {
            "description": "Override the full name of the application",
            "type": "string"
        },
        "image": {
            "description": "Official OCS Inventory image version https://hub.docker.com/r/ocsinventory/ocsinventory-docker-image",
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "description": "Image pullPolicy",
                    "type": "string"
                },
                "registry": {
                    "description": "Image registry",
                    "type": "string"
                },
                "repository": {
                    "description": "Image repository",
                    "type": "string"
                },
                "tag": {
                    "description": "Overrides the image tag whose default is the chart appVersion.",
                    "type": "string"
                }
            }
        },
        "imagePullSecrets": {
            "description": "Image pull secrets",
            "type": "array"
        },
        "ingress": {
            "description": "Allowing use of ingress controllers https://kubernetes.io/docs/concepts/services-networking/ingress/",
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object",
                    "properties": {
                        "cert-manager.io/cluster-issuer": {
                            "type": "string"
                        },
                        "kubernetes.io/ingress.class": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/app-root": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/force-ssl-redirect": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/proxy-body-size": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/proxy-connect-timeout": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/proxy-read-timeout": {
                            "type": "string"
                        },
                        "nginx.ingress.kubernetes.io/proxy-send-timeout": {
                            "type": "string"
                        }
                    }
                },
                "basicauth": {
                    "type": "object",
                    "properties": {
                        "authRealm": {
                            "type": "string"
                        },
                        "enabled": {
                            "type": "boolean"
                        },
                        "password": {
                            "type": "string"
                        },
                        "paths": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "username": {
                            "type": "string"
                        }
                    }
                },
                "className": {
                    "description": "Ingress className",
                    "type": "string"
                },
                "enabled": {
                    "description": "Ingress enabled",
                    "type": "boolean"
                },
                "hosts": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "labels": {
                    "description": "Ingress labels",
                    "type": "object"
                },
                "tls": {
                    "type": "boolean"
                }
            }
        },
        "initContainers": {
            "description": "InitContainers",
            "type": "array"
        },
        "metrics": {
            "type": "object",
            "properties": {
                "enabled": {
                    "description": "Metrics enabled",
                    "type": "boolean"
                },
                "image": {
                    "type": "object",
                    "properties": {
                        "pullPolicy": {
                            "description": "Metrics image pullPolicy",
                            "type": "string"
                        },
                        "registry": {
                            "description": "Metrics image registry",
                            "type": "string"
                        },
                        "repository": {
                            "description": "Metrics image repository",
                            "type": "string"
                        },
                        "tag": {
                            "description": "Metrics image tag",
                            "type": "string"
                        }
                    }
                },
                "resources": {
                    "description": "Metrics ressources",
                    "type": "object",
                    "properties": {
                        "limits": {
                            "type": "object",
                            "properties": {
                                "cpu": {
                                    "type": "string"
                                },
                                "memory": {
                                    "type": "string"
                                }
                            }
                        },
                        "requests": {
                            "type": "object",
                            "properties": {
                                "cpu": {
                                    "type": "string"
                                },
                                "memory": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "serviceMonitor": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "description": "Metrics serviceMonitor enabled",
                            "type": "boolean"
                        },
                        "labels": {
                            "description": "Metrics serviceMonitor labels",
                            "type": "object",
                            "properties": {
                                "prometheus": {
                                    "type": "string"
                                },
                                "release": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "nameOverride": {
            "description": "Override the name of the application",
            "type": "string"
        },
        "nodeSelector": {
            "description": "Node selector labels",
            "type": "object"
        },
        "persistence": {
            "description": "Enable persistence using Persistent Volume Claims https://kubernetes.io/docs/concepts/storage/persistent-volumes/",
            "type": "object",
            "properties": {
                "accessMode": {
                    "description": "PersistentVolumeClaim accessMode",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "annotations": {
                    "description": "PersistentVolumeClaim annotations",
                    "type": "object"
                },
                "enabled": {
                    "description": "Persistence enabled",
                    "type": "boolean"
                },
                "size": {
                    "description": "PersistentVolumeClaim size. If persistence=false the size is used by an emptyDir",
                    "type": "string"
                },
                "storageClass": {
                    "description": "Set storage class here",
                    "type": "string"
                }
            }
        },
        "phpconfig": {
            "description": "PHP configuration https://www.php.net/manual/ini.core.php",
            "type": "object",
            "properties": {
                "ocsinventory": {
                    "type": "string"
                }
            }
        },
        "podAnnotations": {
            "description": "Pod annotations",
            "type": "object"
        },
        "podSecurityContext": {
            "description": "Pod security context",
            "type": "object"
        },
        "resources": {
            "description": "Ressources limits and requests for the container https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/",
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "securityContext": {
            "description": "Security context",
            "type": "object"
        },
        "service": {
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Service annotations",
                    "type": "object"
                },
                "ipFamilies": {
                    "description": "Service ipFamilies",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "ipFamilyPolicy": {
                    "description": "Service ipFamilyPolicy SingleStack|PreferDualStack|RequireDualStack",
                    "type": "string"
                },
                "type": {
                    "description": "Service type",
                    "type": "string"
                }
            }
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Annotations to add to the service account",
                    "type": "object"
                },
                "automount": {
                    "description": "Automatically mount the service account token",
                    "type": "boolean"
                },
                "create": {
                    "description": "Specifies whether a service account should be created",
                    "type": "boolean"
                },
                "name": {
                    "description": "The name of the service account to use. If not set and create is true, a name is generated using the fullname template",
                    "type": "string"
                }
            }
        },
        "tolerations": {
            "description": "Tolerations",
            "type": "array"
        }
    }
}
